{
  "name": "glamar-react-native",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "react-native": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist || rm -rf dist",
    "build:esm": "tsc && node src/make-cjs.cjs",
    "minify": "node src/minify.cjs && node src/obfuscate.cjs",
    "build": "npm run clean && npm run build:esm && npm run minify",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "19.1.0",
    "react-native": "0.80.0",
    "react-native-device-info": "^14.0.4",
    "react-native-webview": "13.15.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": "^1.11.0",
    "buffer": "^6.0.3",
    "crypto-js": "^4.2.0",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.5.0",
    "@types/react": "19.1.11",
    "@types/react-native": "0.72.8",
    "glob": "^11.0.3",
    "javascript-obfuscator": "^4.1.1",
    "react-native-device-info": "^14.0.4",
    "react-native-webview": "13.15.0",
    "rimraf": "6.0.1",
    "terser": "^5.43.1",
    "typescript": "5.9.2"
  }
}
